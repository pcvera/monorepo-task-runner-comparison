{
    "extends": ["//"],
    "tasks": {
        "strip-comments": {
            "inputs": ["src/**/*.js"],
            "outputs": ["build/stripped-comments/**"]
        },
        "build": {
            "dependsOn": ["strip-comments"],
            "inputs": ["build/stripped-comments/**", "src/build-only.json"],
            "outputs": ["dist/**"]
        }
    }
}