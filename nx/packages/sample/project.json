{
  "name": "sample",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/sample/src",
  "targets": {
    "strip-comments": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/strip-comments.cjs",
        "cwd": "{projectRoot}"
      },
      "inputs": ["stripCommentsSources"],
      "outputs": ["{projectRoot}/build/stripped-comments"]
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["strip-comments"],
      "options": {
        "command": "node scripts/dummy-build.cjs",
        "cwd": "{projectRoot}"
      },
      "inputs": ["strippedCommentsForBuild", "buildOnlySources"],
      "outputs": ["{projectRoot}/dist"]
    }
  },
  "tags": []
}
