{
  "name": "sample",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/sample/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "node scripts/dummy-build.cjs",
        "cwd": "{projectRoot}"
      },
      "inputs": ["buildOnlySources", "{projectRoot}/scripts/**/*.cjs"],
      "outputs": ["{projectRoot}/dist"]
    }
  },
  "tags": []
}
