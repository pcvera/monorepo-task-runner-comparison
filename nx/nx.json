{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": ["default"],
    "sharedGlobals": [],
    "stripCommentsSources": ["{projectRoot}/src/**/*.js"],
    "buildOnlySources": ["{projectRoot}/src/**/*.json"]
  },
  "neverConnectToCloud": true,
  "analytics": false,
  "tui": {
    "enabled": false
  },
  "targetDefaults": {
    "build": {
      "cache": true
    }
  }
}
