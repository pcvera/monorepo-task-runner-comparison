{
  "name": "@repo/sample",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "wireit"
  },
  "dependencies": {
    "@repo/stripped": "workspace:*"
  },
  "wireit": {
    "build": {
      "command": "node scripts/dummy-build.cjs",
      "dependencies": ["../stripped:build"],
      "files": [
        "src/**/*.json",
        "scripts/**/*.cjs",
        "../stripped/build/stripped-comments/**"
      ],
      "output": ["dist/**"]
    }
  }
}
